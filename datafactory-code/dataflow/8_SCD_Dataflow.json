{
	"name": "8_SCD_Dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "8_scd_source_prop",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "8_AzureSqlTable_dest_prop",
						"type": "DatasetReference"
					},
					"name": "sink8"
				}
			],
			"transformations": [
				{
					"name": "alterRow8"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Employee_ID as short,",
				"          First_Name as string,",
				"          Salary as integer,",
				"          Location as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     partitionBy('hash', 1)) ~> source",
				"source alterRow(upsertIf(1==1),",
				"     partitionBy('hash', 1)) ~> alterRow8",
				"alterRow8 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['Employee_ID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          Employee_ID,",
				"          First_Name,",
				"          Salary,",
				"          Location",
				"     ),",
				"     partitionBy('hash', 1)) ~> sink8"
			]
		}
	}
}